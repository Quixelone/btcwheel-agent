# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook (used to send scraped products to the edge function)
SUPABASE_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/scrape-dual-investment
OPENCLAW_WEBHOOK_SECRET=your-webhook-secret

# WhatsApp
WHATSAPP_SESSION_NAME=btcwheel-session
# Optional fallback recipients (comma-separated, international format without +).
# If empty, the agent reads active subscribers from Supabase table whatsapp_subscribers.
WHATSAPP_RECIPIENTS=

# Scraping config
SCRAPE_SCHEDULE=5 8 * * *
SCRAPE_HEADLESS=true
