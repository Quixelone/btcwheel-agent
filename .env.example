# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook (used to send scraped products to the edge function)
SUPABASE_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/scrape-dual-investment
OPENCLAW_WEBHOOK_SECRET=your-webhook-secret

# WhatsApp
WHATSAPP_SESSION_NAME=btcwheel-session
# Comma-separated list of recipient phone numbers in international format (no +)
WHATSAPP_RECIPIENTS=390000000000,390000000001

# Scraping config
SCRAPE_SCHEDULE=5 8 * * *
SCRAPE_HEADLESS=true
